                        <Array as="points">
                            <mxPoint x="1340" y="2036"/>
                            <mxPoint x="1340" y="346"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="59" value="&lt;span style=&quot;font-size: 9pt; line-height: 107%; font-family: Helvetica, sans-serif; background-image: initial; background-position: initial; background-size: initial; background-repeat: initial; background-attachment: initial; background-origin: initial; background-clip: initial;&quot;&gt;Nick enlève la goupille&lt;br&gt;d'une grenade, mais une blessure à son bras fait en sorte qu'il l'échappe, ce&lt;br&gt;qui tue tout votre escadron.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="840" y="1975.5" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="60" value="&lt;p class=&quot;MsoNormal&quot;&gt;&lt;span style=&quot;font-size: 9pt; line-height: 107%; font-family: Helvetica, sans-serif; background-image: initial; background-position: initial; background-size: initial; background-repeat: initial; background-attachment: initial; background-origin: initial; background-clip: initial;&quot;&gt;Bombe fait le kamikaze&lt;br/&gt;et élimine l'ennemi ce qui crée la zone sécurisée. L'objectif est sauvé. Vous&lt;br/&gt;avez maintenant des chances de gagner la guerre avec l'immortel.&lt;/span&gt;&lt;/p&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#60a917;fontColor=#ffffff;strokeColor=#2D7600;" parent="1" vertex="1">
