                <mxCell id="70" value="Vous" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" parent="69" vertex="1" connectable="0">
                    <mxGeometry x="-0.3119" y="1" relative="1" as="geometry">
                        <mxPoint as="offset"/>
